# Production / extension: deployed site origin (no trailing slash, no /api path)
# VITE_SPOTIFY_API_BASE_URL=https://your-app.vercel.app

# Local dev only: where to proxy /api/* (Vite has no serverless functions)
# Defaults to https://pixel-start.vercel.app if unset
# VITE_DEV_API_PROXY=https://your-app.vercel.app
